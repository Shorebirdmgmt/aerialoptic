---
import { cfImg } from '../lib/img';
import { fetchPhotos } from '../lib/api';
import LoadingScreen from '../components/LoadingScreen.astro';

const instaPhotos = await fetchPhotos('Instagram');

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
  heroPreload?: string;
  ogImage?: string;
}

const SITE = 'https://aerialoptic.net';
const CDN = 'https://cdn.aerialoptic.net';
const OG_DEFAULT = `${CDN}/aerialoptic/images/og/og-default.jpg`;

const { title, description = 'FAA Part 107 certified aerial photography and videography based in Kingsville, Maryland. Drone coverage for marine, real estate, construction, events, and commercial clients.', currentPage = '', heroPreload, ogImage } = Astro.props;

const pageUrl = `${SITE}${Astro.url.pathname}`;
const ogImg = ogImage || OG_DEFAULT;
---
<!DOCTYPE html>
<html lang="en-US">
	<head>
		<meta charset="UTF-8">
		<script is:inline>if(sessionStorage.getItem('loading-screen-shown')){document.documentElement.classList.add('no-loading')}</script>
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="theme-color" content="#147170" />
		<link rel="canonical" href={pageUrl} />
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Aerial Optic" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={pageUrl} />
		<meta property="og:image" content={ogImg} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Aerial Optic — Eyes from the Skies" />
		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImg} />
		<meta name="twitter:image:alt" content="Aerial Optic — Eyes from the Skies" />
		<!-- Apple -->
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="Aerial Optic" />
		<!-- Self-hosted Manrope (variable font, latin subset) -->
		<link rel="preload" href="/fonts/manrope-latin.woff2" as="font" type="font/woff2" crossorigin>
		<style is:inline>
			@font-face {
				font-family: 'Manrope';
				font-style: normal;
				font-weight: 400 700;
				font-display: swap;
				src: url('/fonts/manrope-latin.woff2') format('woff2');
				unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
			}
		</style>
		<!-- Bootstrap CSS -->
		<link rel='stylesheet' id='bootstrap-css'  href='/css/bootstrap/css/bootstrap.min.css' type='text/css' media='all' />
		<!-- Font Awesome Icons CSS -->
		<link rel='stylesheet' id='font-awesome'  href='/css/fontawesome/css/font-awesome.min.css' type='text/css' media='all' />
		<!-- Main CSS File -->
		<link rel='stylesheet' id='tilia-style-css'  href='/style.css' type='text/css' media='all' />
		<!-- favicons -->
		<link rel="icon" type="image/png" href="/images/icons/favicon-32x32.png" sizes="32x32" />
		<link rel="icon" type="image/png" href="/images/icons/favicon-192x192.png" sizes="192x192" />
		<link rel="apple-touch-icon" href="/images/icons/favicon-180x180.png" />
		<!-- Hero image preload -->
		{heroPreload && <link rel="preload" as="image" fetchpriority="high" imagesrcset={heroPreload} imagesizes="100vw" />}
		<slot name="head" />
	</head>
	<body class="home home-3" data-loading="true">
		<LoadingScreen logoSrc="/images/logo-aerial-optic-badge.png" brandName="Aerial Optic" variant="ease" />
		<div class="menu-mask">
			<!-- MOBILE MENU HOLDER -->
			<div class="container mobile-menu-holder">
				<div class="row">
					<div class="col-lg-7">
						<!-- MOBILE MENU -->
						<ul class="menu-mobile">
								<li class:list={["menu-item", { "current-menu-item": currentPage === "home" }]}><a href="/">Home</a></li>
								<li class:list={["menu-item", { "current-menu-item": currentPage === "portfolio" }]}><a href="/portfolio">Portfolio</a></li>
								<li class:list={["menu-item", { "current-menu-item": currentPage === "about" }]}><a href="/about">About</a></li>
								<li class:list={["menu-item", { "current-menu-item": currentPage === "contact" }]}><a href="/contact">Contact</a></li>
							</ul>
							<!-- /MOBILE MENU -->
					</div>
					<!-- /col-lg-7 -->
					<div class="col-lg-5">
						<div class="menu-contact">
							<div class="mobile-content">
								<h5 class="widgettitle">Main Office</h5>
								<div class="mobile-address"> Kingsville, MD 21087 <br> 443-966-5968 <br> aerialoptic1@outlook.com</div>
								<h5 class="widgettitle">Social</h5>
								<ul class="social-media">
									<li><a class="social-facebook" href="https://www.facebook.com/AerialOptic" target="_blank">Facebook</a></li>
									<li><a class="social-twitter" href="https://www.tiktok.com/@Aerial__optic" target="_blank">TikTok</a></li>
									<li><a class="social-instagram" href="https://www.instagram.com/Aerial__Optic" target="_blank">Instagram</a></li>
									<li><a class="social-email" href="mailto:aerialoptic1@outlook.com" target="_blank">Email</a></li>
								</ul>
							</div>
						</div>
					</div>
					<!-- /col-lg-5 -->
				</div>
				<!-- /row -->
			</div>
			<!-- /container -->
		</div>
		<!-- /MOBILE MENU HOLDER -->
		<!-- HEADER -->
		<header class="main-header header-5">
			<div class="container">
				<div class="top-header top-header-5">
					<div class="header-social header-social-5">
						<ul class="social-media">
							<li><a class="social-facebook" href="https://www.facebook.com/AerialOptic" target="_blank"><i class="fab fa-facebook-f"></i></a></li>
							<li><a class="social-twitter" href="https://www.tiktok.com/@Aerial__optic" target="_blank"><i class="fab fa-tiktok"></i></a></li>
							<li><a class="social-instagram" href="https://www.instagram.com/Aerial__Optic" target="_blank"><i class="fab fa-instagram"></i></a></li>
							<li><a class="social-email" href="mailto:aerialoptic1@outlook.com" target="_blank"><i class="far fa-envelope"></i></a></li>
						</ul>
					</div>
					<div class="logo logo-5 logo-white"><a href="/"><img class="img-fluid" src={cfImg('images/logo-aerial-optic-badge.png', { w: 278, q: 80 })} alt="Aerial Optic" width="278" height="180" decoding="async"></a></div>
					<div class="logo logo-5 logo-dark"><a href="/"><img class="img-fluid" src={cfImg('images/logo-aerial-optic-badge.png', { w: 278, q: 80 })} alt="Aerial Optic" width="278" height="180" decoding="async"></a></div>
					<div class="btn-header btn-header-5"> <a href="/contact" class="read-more">Book a Session</a></div>
					<!-- mobile menu button -->
					<div class="nav-button-holder nav-button-holder-5">
						<button type="button" class="nav-button">
							<svg version="1.1" id="btn-menu-open" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 16 16" style="enable-background:new 0 0 16 16;" xml:space="preserve">
								<g>
									<path d="M2,4L2,4C0.9,4,0,3.1,0,2v0c0-1.1,0.9-2,2-2h0c1.1,0,2,0.9,2,2v0C4,3.1,3.1,4,2,4z"></path>
									<path d="M8,4L8,4C6.9,4,6,3.1,6,2v0c0-1.1,0.9-2,2-2h0c1.1,0,2,0.9,2,2v0C10,3.1,9.1,4,8,4z"></path>
									<path d="M14,4L14,4c-1.1,0-2-0.9-2-2v0c0-1.1,0.9-2,2-2h0c1.1,0,2,0.9,2,2v0C16,3.1,15.1,4,14,4z"></path>
									<path d="M2,10L2,10c-1.1,0-2-0.9-2-2v0c0-1.1,0.9-2,2-2h0c1.1,0,2,0.9,2,2v0C4,9.1,3.1,10,2,10z"></path>
									<path d="M8,10L8,10c-1.1,0-2-0.9-2-2v0c0-1.1,0.9-2,2-2h0c1.1,0,2,0.9,2,2v0C10,9.1,9.1,10,8,10z"></path>
									<path d="M14,10L14,10c-1.1,0-2-0.9-2-2v0c0-1.1,0.9-2,2-2h0c1.1,0,2,0.9,2,2v0C16,9.1,15.1,10,14,10z"></path>
									<path d="M2,16L2,16c-1.1,0-2-0.9-2-2v0c0-1.1,0.9-2,2-2h0c1.1,0,2,0.9,2,2v0C4,15.1,3.1,16,2,16z"></path>
									<path d="M8,16L8,16c-1.1,0-2-0.9-2-2v0c0-1.1,0.9-2,2-2h0c1.1,0,2,0.9,2,2v0C10,15.1,9.1,16,8,16z"></path>
									<path d="M14,16L14,16c-1.1,0-2-0.9-2-2v0c0-1.1,0.9-2,2-2h0c1.1,0,2,0.9,2,2v0C16,15.1,15.1,16,14,16z"></path>
								</g>
							</svg>
							<span class="hamburger-mid"></span>
						</button>
					</div>
					<!-- /mobile menu button -->
				</div>
				<!-- /top-header -->
				<div class="header-container5"><a href="/" class="sticky-logo"><img src={cfImg('images/logo-aerial-optic-badge.png', { w: 200, q: 80 })} alt="Aerial Optic" width="200" height="130" decoding="async"></a>
					<nav class="nav-holder nav-holder-5">
						<ul class="menu-nav">
								<li class:list={["menu-item", { "current-menu-item": currentPage === "home" }]}><a href="/">Home</a></li>
								<li class:list={["menu-item", { "current-menu-item": currentPage === "portfolio" }]}><a href="/portfolio">Portfolio</a></li>
								<li class:list={["menu-item", { "current-menu-item": currentPage === "about" }]}><a href="/about">About</a></li>
								<li class:list={["menu-item", { "current-menu-item": currentPage === "contact" }]}><a href="/contact">Contact</a></li>
							</ul>
						</nav>
				</div>
			</div>
		</header>
		<!-- /HEADER -->
		<slot />
		<!-- FOOTER -->
		<div id="footer-instagram">
			<div class="swiper insta-swiper">
				<div class="swiper-wrapper">
					{instaPhotos.map(photo => (
						<div class="swiper-slide"><a href="https://www.instagram.com/Aerial__Optic" target="_blank"><img src={cfImg(photo.r2_key, { w: 240 })} alt="Aerial Optic Instagram" width="240" height="240" loading="lazy" decoding="async"></a></div>
					))}
				</div>
			</div>
			<p class="clear"><a href="https://www.instagram.com/Aerial__Optic" rel="me" target="_blank" class="">Follow Us!</a></p>
		</div>
		<slot name="before-footer" />
		<footer>
			<div class="container">
				<div class="footer-widgets">
					<div class="row align-items-center">
						<div class="col-lg-4 col-sm-12" style="margin-bottom: 30px;">
							<a href="/"><img src={cfImg('images/logo-aerial-optic-badge.png', { w: 260, q: 80 })} alt="Aerial Optic — Eyes from the Skies" style="max-width: 260px; width: 100%;" width="260" height="169" loading="lazy" decoding="async"></a>
							<p style="margin-top: 15px; font-size: 14px; line-height: 1.6; color: #aaa;">FAA Part 107 certified aerial photography and videography based in Kingsville, Maryland. Capturing your world from a whole new perspective.</p>
						</div>
						<div class="col-lg-8 col-sm-12">
							<div class="row" style="text-align: center;">
								<div class="col-lg-4 col-sm-6">
									<div class="foo-block">
										<div class="widget_text widget widget-footer">
											<h5 class="widgettitle">Contact Us</h5>
											<ul class="footer-contact">
												<li><a href="https://maps.google.com/?q=Kingsville+MD+21087" target="_blank"><i class="fas fa-map-marker-alt"></i><span>Kingsville, MD 21087</span></a></li>
												<li><a href="tel:+14439665968"><i class="fas fa-mobile-alt"></i><span>443-966-5968</span></a></li>
												<li><a href="mailto:aerialoptic1@outlook.com"><i class="far fa-envelope"></i><span>aerialoptic1@outlook.com</span></a></li>
											</ul>
										</div>
									</div>
								</div>
								<div class="col-lg-4 col-sm-6">
									<div class="foo-block">
										<div class="widget_text widget widget-footer">
											<h5 class="widgettitle">Quick Links</h5>
											<ul>
												<li><a href="/">Home</a></li>
												<li><a href="/about">About</a></li>
												<li><a href="/portfolio">Portfolio</a></li>
												<li><a href="/contact">Contact</a></li>
											</ul>
										</div>
									</div>
								</div>
								<div class="col-lg-4 col-sm-6">
									<div class="foo-block foo-last">
										<div class="widget widget-footer">
											<h5 class="widgettitle">Follow</h5>
											<ul>
												<li><a href="https://www.facebook.com/AerialOptic">Facebook</a></li>
												<li><a href="https://www.tiktok.com/@Aerial__optic">TikTok</a></li>
												<li><a href="https://www.instagram.com/Aerial__Optic">Instagram</a></li>
											</ul>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="copyright">
					<div class="footer-copy" style="display: flex; justify-content: space-between; align-items: center;"><span><span class="footer-year">2026</span> &copy; Aerial Optic. All rights reserved.</span><span>Built by: <a href="https://shorebirdmanagement.com/" target="_blank">Shorebird Management</a></span></div>
				</div>
			</div>
		</footer>
		<!-- /FOOTER -->
		<div class="scrollup">
			<a class="scrolltop" href="#">
			<i class="fa fa-chevron-up"></i>
			</a>
		</div>
		<!-- JS -->
		<script is:inline src='/js/jquery.js'></script>
		<script is:inline src='/js/jquery-migrate.min.js'></script>
		<script is:inline src='/css/bootstrap/js/popper.min.js'></script>
		<script is:inline src='/css/bootstrap/js/bootstrap.min.js'></script>
		<script is:inline src='/js/jquery.easing.min.js'></script>
		<script is:inline src='/js/swiper.js'></script>
		<script is:inline src='/js/isotope.js'></script>
		<script is:inline src='/js/simple-lightbox.js'></script>
		<!-- MAIN JS -->
		<script is:inline src='/js/init.js'></script>
		<script is:inline src='/js/ao-extras.js'></script>
		<script is:inline src='/js/lightbox.js'></script>
		<script is:inline src='/realtime.js'></script>
		<slot name="scripts" />
	</body>
</html>
