									<div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 25px; text-align: center; background: linear-gradient(transparent, rgba(0,0,0,0.75));">
										<h3 style="color: #fff; margin: 0 0 5px; font-family: var(--headings-font); font-size: 1.5rem;">Powerboats</h3>
										<span style="color: rgba(255,255,255,0.8); font-size: 14px;">High-performance boats on the Chesapeake</span>
									</div>
								</div>
							</a>
						</div>
						<div class="col-lg-4 col-md-6 sr sr-delay-2" style="margin-bottom: 30px;">
							<a href="/portfolio-sportfishing" style="display: block; text-decoration: none; color: inherit;">
								<div class="portfolio-card" style="position: relative; overflow: hidden;">
									<img loading="lazy" decoding="async" src={cfImg('images/portfolio/featured-images/sf-wmo-1.jpg', { w: 640 })} srcset={cfSrcset('images/portfolio/featured-images/sf-wmo-1.jpg', { widths: [320, 480, 640] })} alt="Sportfishing" sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw" width="640" height="480" style="width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block;">
									<div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 25px; text-align: center; background: linear-gradient(transparent, rgba(0,0,0,0.75));">
										<h3 style="color: #fff; margin: 0 0 5px; font-family: var(--headings-font); font-size: 1.5rem;">Sportfishing</h3>
										<span style="color: rgba(255,255,255,0.8); font-size: 14px;">Offshore action and tournament coverage</span>
									</div>
								</div>
							</a>
						</div>
						<div class="col-lg-4 col-md-6 sr sr-delay-3" style="margin-bottom: 30px;">
							<a href="/portfolio-local-business" style="display: block; text-decoration: none; color: inherit;">
