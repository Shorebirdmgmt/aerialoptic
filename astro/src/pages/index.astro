									</div>
								</div>
							</a>
						</div>
						<div class="col-lg-4 col-md-6 sr sr-delay-4" style="margin-bottom: 30px;">
							<a href="/portfolio-construction" style="display: block; text-decoration: none; color: inherit;">
								<div class="portfolio-card" style="position: relative; overflow: hidden;">
									<img loading="lazy" decoding="async" src={cfImg('images/portfolio/featured-images/con-crane-1.jpg', { w: 640 })} srcset={cfSrcset('images/portfolio/featured-images/con-crane-1.jpg', { widths: [320, 480, 640] })} alt="Construction" sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw" width="640" height="480" style="width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block;">
									<div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 25px; text-align: center; background: linear-gradient(transparent, rgba(0,0,0,0.75));">
										<h3 style="color: #fff; margin: 0 0 5px; font-family: var(--headings-font); font-size: 1.5rem;">Construction</h3>
										<span style="color: rgba(255,255,255,0.8); font-size: 14px;">Documenting progress from above</span>
									</div>
								</div>
							</a>
						</div>
						<div class="col-lg-4 col-md-6 sr sr-delay-5" style="margin-bottom: 30px;">
							<a href="/portfolio-realestate" style="display: block; text-decoration: none; color: inherit;">
								<div class="portfolio-card" style="position: relative; overflow: hidden;">
									<img loading="lazy" decoding="async" src={cfImg('images/portfolio/featured-images/re-waterfront-1.jpg', { w: 640 })} srcset={cfSrcset('images/portfolio/featured-images/re-waterfront-1.jpg', { widths: [320, 480, 640] })} alt="Real Estate" sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw" width="640" height="480" style="width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block;">
									<div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 25px; text-align: center; background: linear-gradient(transparent, rgba(0,0,0,0.75));">
										<h3 style="color: #fff; margin: 0 0 5px; font-family: var(--headings-font); font-size: 1.5rem;">Real Estate</h3>
										<span style="color: rgba(255,255,255,0.8); font-size: 14px;">Stunning property aerials that sell</span>
									</div>
								</div>
							</a>
						</div>
						<div class="col-lg-4 col-md-6 sr sr-delay-6" style="margin-bottom: 30px;">
							<a href="/portfolio-events" style="display: block; text-decoration: none; color: inherit;">
								<div class="portfolio-card" style="position: relative; overflow: hidden;">
									<img loading="lazy" decoding="async" src={cfImg('images/portfolio/featured-images/ev-carshow-1.jpg', { w: 640 })} srcset={cfSrcset('images/portfolio/featured-images/ev-carshow-1.jpg', { widths: [320, 480, 640] })} alt="Events" sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw" width="640" height="480" style="width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block;">
									<div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 25px; text-align: center; background: linear-gradient(transparent, rgba(0,0,0,0.75));">
										<h3 style="color: #fff; margin: 0 0 5px; font-family: var(--headings-font); font-size: 1.5rem;">Events</h3>
										<span style="color: rgba(255,255,255,0.8); font-size: 14px;">Car shows, boat rallies, and community gatherings</span>
									</div>
								</div>
							</a>
						</div>
					</div>
					<div class="margin-t50 alignc sr">
						<a href="/portfolio" class="read-more">View full portfolio</a>
					</div>
				</div>
			</div>
			<!-- /SECTION 2 -->
			<!-- SECTION 3 -->
			<div id="home-section-3-3" class="section-holder home-section-3-3 margin-b50">
				<div class="row g-0 align-items-center">
					<div class="col-lg-6 margin-bm50 sr" style={`background: url(${lqipContact}) center/cover`}>
						<img class="img-fluid radius-right250" src={cfImg('images/pages/contact-page.jpg', { w: 800 })} alt="Aerial drone over marina" width="800" height="533" loading="lazy" decoding="async">
					</div>
					<!-- /col-lg-6 -->
					<div class="col-lg-6 sr sr-delay-2">
						<div class="padding-50">
							<div class="testimonials">
								<div class="testimonial-quote">
									<svg version="1.1" class="icon-quote2" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 512 512" style="enable-background:new 0 0 512 512;" xml:space="preserve">
										<g>
											<g>
												<path d="M84.2,437.2c-7.2,0-14.2-3.2-18.9-9.1c-6.7-8.4-6.9-20.3-0.7-29c16.6-22.9,28-49.4,33.1-77C72,316.2,48.6,302.3,31,282.2
													c-20-22.8-31-52-31-82.3c0-69,56.1-125.1,125.1-125.1s125.1,56.1,125.1,125.1c0,103.2-61.6,195.6-156.8,235.4
													C90.4,436.6,87.3,437.2,84.2,437.2z M125.1,94.1c-58.4,0-105.9,47.5-105.9,105.9c0,52.4,39.1,97.4,90.9,104.8l9.5,1.3l-1.3,9.5
