---
import Base from '../layouts/Base.astro';
import { cfImg, cfSrcset } from '../lib/img';

// Responsive slider images — 4 breakpoints matching srcset widths
const sliderSrcs = [1, 2, 3].map(i => ({
	sm:  cfImg(`images/home/slider-${i}.jpg`, { w: 480 }),
	md:  cfImg(`images/home/slider-${i}.jpg`, { w: 768 }),
	lg:  cfImg(`images/home/slider-${i}.jpg`, { w: 1200 }),
	xl:  cfImg(`images/home/slider-${i}.jpg`, { w: 1920 }),
}));

const lqip1 = 'data:image/webp;base64,UklGRnIAAABXRUJQVlA4IGYAAADQAwCdASogABIAPzmEt1OvKCUkMAgB4CcJZADM0BhiX/w8wuM97AAA/s0Ge2gnEjjeF2ntKawT1bV+NugPejxv9nk83maatZpSn5uoqxPw4R+KHhLL5W1Nhxh3wjHBvXhb1z4AAAA=';
const lqipContact = 'data:image/webp;base64,UklGRmQAAABXRUJQVlA4IFgAAAAwBACdASogABIAPzmEt1OvKKUisAgB4CcJZwAAQtvKyitet9UB0+1Pu4AA/rny5hCNZ7tGpFNuoFaSJkhM2A5caheQK+y/59DfN3wGnTUAhLq37do8AAAA';
---
<Base title="Aerial Optic — Cinematic Drone Photography in Maryland" description="FAA Part 107 certified drone pilot in Kingsville, MD. Aerial photography and videography for marine, real estate, construction, events, and commercial clients." currentPage="home" heroPreload={cfSrcset('images/home/slider-1.jpg')}>
		<Fragment slot="head"><style set:html={`
			.slide-1{background-image:url('${sliderSrcs[0].sm}')}
			.slide-2{background-image:url('${sliderSrcs[1].sm}')}
			.slide-3{background-image:url('${sliderSrcs[2].sm}')}
			@media(min-width:481px){
				.slide-1{background-image:url('${sliderSrcs[0].md}')}
				.slide-2{background-image:url('${sliderSrcs[1].md}')}
				.slide-3{background-image:url('${sliderSrcs[2].md}')}
			}
			@media(min-width:769px){
				.slide-1{background-image:url('${sliderSrcs[0].lg}')}
				.slide-2{background-image:url('${sliderSrcs[1].lg}')}
				.slide-3{background-image:url('${sliderSrcs[2].lg}')}
			}
			@media(min-width:1201px){
				.slide-1{background-image:url('${sliderSrcs[0].xl}')}
				.slide-2{background-image:url('${sliderSrcs[1].xl}')}
				.slide-3{background-image:url('${sliderSrcs[2].xl}')}
			}
		`}></style></Fragment>
		<!-- /HEADER -->
		<!-- HOME SLIDER -->
		<div class="swiper-mt" style={`background: url(${lqip1}) center/cover`}>
			<div class="swiper-wrapper">
				<div class="swiper-slide slider-img slide-1">
					<div class="container slider-caption">
						<div class="slider-text">
							<h1 class="display-2">Stunning Aerial Photography</h1>
							<span class="post-subtitle"> Capture breathtaking moments from above with our expert drone shots.</span> <a href="/contact" class="read-more white-btn">Book a Session</a>
						</div>
					</div>
				</div>
				<!-- /slider-img -->
				<div class="swiper-slide slider-img slide-2">
					<div class="container slider-caption">
						<div class="slider-text">
							<h1 class="display-2">Eyes from the Skies</h1>
							<span class="post-subtitle"> Professional drone photography for marine, real estate, events, and more.</span> <a href="/portfolio" class="read-more white-btn">View Portfolio</a>
						</div>
					</div>
				</div>
				<!-- /slider-img -->
				<div class="swiper-slide slider-img slide-3">
					<div class="container slider-caption">
						<div class="slider-text">
							<h1 class="display-2">Cinematic Drone Coverage</h1>
							<span class="post-subtitle"> From offshore fishing to luxury real estate, we deliver stunning aerial visuals.</span> <a href="/contact" class="read-more white-btn">Book a Session</a>
						</div>
					</div>
				</div>
				<!-- /slider-img -->
			</div>
			<!-- /swiper-wrapper -->
			<div class="swiper-mt-button-prev" tabindex="0" role="button" aria-label="Previous slide">
				<svg version="1.1" class="arrow-slider" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 55 55" style="enable-background:new 0 0 55 55;" xml:space="preserve">
					<path d="M33.2,28.3l-8.8,8.8c-0.4,0.4-1.1,0.4-1.5,0l-1-1c-0.4-0.4-0.4-1.1,0-1.5l7-7l-7-7c-0.4-0.4-0.4-1.1,0-1.5l1-1
						c0.4-0.4,1.1-0.4,1.5,0l8.8,8.8C33.6,27.2,33.6,27.8,33.2,28.3z"></path>
					<path d="M27.5,55C12.3,55,0,42.7,0,27.5S12.3,0,27.5,0S55,12.3,55,27.5S42.7,55,27.5,55z M27.5,5C15.1,5,5,15.1,5,27.5
						S15.1,50,27.5,50S50,39.9,50,27.5S39.9,5,27.5,5z"></path>
				</svg>
			</div>
			<!-- /swiper-mt-button-prev -->
			<div class="swiper-mt-button-next" tabindex="0" role="button" aria-label="Next slide">
				<svg version="1.1" class="arrow-slider" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 55 55" style="enable-background:new 0 0 55 55;" xml:space="preserve">
					<path d="M33.2,28.3l-8.8,8.8c-0.4,0.4-1.1,0.4-1.5,0l-1-1c-0.4-0.4-0.4-1.1,0-1.5l7-7l-7-7c-0.4-0.4-0.4-1.1,0-1.5l1-1
						c0.4-0.4,1.1-0.4,1.5,0l8.8,8.8C33.6,27.2,33.6,27.8,33.2,28.3z"></path>
					<path d="M27.5,55C12.3,55,0,42.7,0,27.5S12.3,0,27.5,0S55,12.3,55,27.5S42.7,55,27.5,55z M27.5,5C15.1,5,5,15.1,5,27.5
						S15.1,50,27.5,50S50,39.9,50,27.5S39.9,5,27.5,5z"></path>
				</svg>
			</div>
			<!-- /swiper-mt-button-next -->
		</div>
		<!-- /swiper-mt -->
		<!-- /HOME SLIDER -->
		<!-- WRAP CONTENT -->
		<div id="wrap-content" class="page-content custom-page-template">
			<!-- SECTION 1 -->
			<div id="home-section-3-1" class="section-holder home-section-3-1">
				<div class="container">
					<div class="row align-items-center">
						<div class="col-lg-3 section-hide-mobile">
							<div class="margin-r50 sr">
								<img class="img-fluid radius10 margin-b30" src={cfImg('images/home/home2-img1.jpg', { w: 480 })} alt="Aerial beach photography" width="480" height="640" loading="lazy" decoding="async" />
								<img class="img-fluid radius10" src={cfImg('images/home/home2-img3.jpg', { w: 480 })} alt="Aerial construction site" width="480" height="640" loading="lazy" decoding="async" />
							</div>
							<!-- /margin-r50 -->
						</div>
						<!-- /col-lg-3 -->
						<div class="col-lg-6 alignc">
							<div class="el-smalltitle sr">About Aerial Optic</div>
							<h2 class="display-4 margin-b30 sr sr-delay-1">We Capture Stunning Aerial Images That Tell Your Story</h2>
							<p class="sr sr-delay-2">At Aerial Optic, we believe that every picture tells a story. As an FAA Part 107 certified drone pilot based in Kingsville, Maryland, we specialize in cinematic aerial photography and videography for marine, real estate, construction, events, and commercial clients. Whether chasing sportfishing boats offshore or showcasing a waterfront property from above, we deliver powerful visuals that elevate your brand.</p>
							<div class="margin-t30">
								<a href="/contact" class="read-more">Get in Touch</a>
							</div>
						</div>
						<!-- /col-lg-6 -->
						<div class="col-lg-3 section-hide-mobile">
							<div class="margin-l50 sr sr-delay-3">
								<img class="img-fluid radius10 margin-t30" src={cfImg('images/home/home2-img2.jpg', { w: 480 })} alt="Aerial waterfront view" width="480" height="640" loading="lazy" decoding="async" />
								<img class="img-fluid radius10  margin-t30" src={cfImg('images/home/home2-img4.jpg', { w: 480 })} alt="Aerial marina shot" width="480" height="640" loading="lazy" decoding="async" />
							</div>
							<!-- /margin-l50 -->
						</div>
						<!-- /col-lg-3 -->
					</div>
					<!-- /row -->
				</div>
				<!-- /container -->
			</div>
			<!-- /SECTION 1 -->
			<!-- SECTION 2 -->
			<div id="home-section-3-2" class="section-holder home-section-3-2 margin-b50">
