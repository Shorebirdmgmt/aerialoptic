---
import Base from '../layouts/Base.astro';
import { cfImg, cfSrcset } from '../lib/img';
import { fetchPhotos } from '../lib/api';

const photos = await fetchPhotos('Construction');
const heroPhoto = photos[0];
---
<Base title="Construction Drone Photography | Aerial Optic" description="Aerial drone photography of construction sites — progress documentation, crane operations, and marine infrastructure projects." currentPage="portfolio" heroPreload={heroPhoto ? cfSrcset(heroPhoto.r2_key) : undefined} ogImage={heroPhoto ? cfImg(heroPhoto.r2_key, { w: 1200, q: 80 }) : undefined}>
		<!-- PAGE HERO -->
		<div class="top-single-bkg" style="height: 65vh;">
			<div class="topsingleimg">
				{heroPhoto && <img src={cfImg(heroPhoto.r2_key, { w: 1920 })} srcset={cfSrcset(heroPhoto.r2_key)} sizes="100vw" alt="Construction" width="1920" height="1080" loading="eager" fetchpriority="high" decoding="async">}
			</div>
			<div class="inner-desc">
				<div class="container">
					<h1 class="single-post-title display-2">Construction</h1>
					<span class="post-subtitle">Portfolio</span>
				</div>
			</div>
		</div>
		<!-- /PAGE HERO -->
		<!-- WRAP CONTENT -->
		<div id="wrap-content" class="page-content custom-page-template">
			<div class="section-holder" style="padding: 60px 0;">
				<div class="container">
					<a href="/portfolio" class="read-more back-btn" style="margin-bottom: 40px;"><i class="fa fa-chevron-left" style="margin-right: 8px;"></i> Back to Portfolio</a>
					<div class="row">
						{photos.map((photo) => (
							<div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
								<div class="ao-gallery-item">
									<img src={cfImg(photo.r2_key, { w: 640 })} srcset={cfSrcset(photo.r2_key, { widths: [320, 480, 640] })} sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw" alt={photo.title || ''} width="640" height="427" loading="lazy" decoding="async" style="width: 100%; display: block;">
								</div>
								{photo.caption && <p class="ao-gallery-caption" style="margin-top: 10px; font-size: 14px; color: #858585;">{photo.caption}</p>}
							</div>
						))}
					</div>
				</div>
			</div>
			<!-- CTA -->
			<div class="section-holder section-info padding-tb100 section-nomargin" style="background: var(--primary-color);">
				<div class="container">
					<div class="row">
						<div class="col-lg-12">
							<div class="padding-lr200 alignc">
								<h2 class="display-4 margin-b30" style="color: #fff;">Like what you see?</h2>
								<p style="color: rgba(255,255,255,0.8);">Let's capture your next project from a whole new perspective.</p>
								<a href="/contact" class="read-more white-btn margin-t30">Book a Session</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<!-- /WRAP CONTENT -->
</Base>
