---
import Base from '../layouts/Base.astro';
import { cfImg, cfSrcset } from '../lib/img';
---
<Base title="Offshore charter coverage — Sportfishing — Aerial Optic" description="Documenting offshore fishing charters from dock to deep blue — every strike, every run, every victory." currentPage="portfolio" heroPreload={cfSrcset('images/home/slider-2.jpg')} ogImage={cfImg('images/home/slider-2.jpg', { w: 1200, q: 80 })}>
		<div class="top-single-bkg" style="height: 50vh; position: relative; overflow: hidden;">
			<div class="topsingleimg">
				<img src={cfImg('images/home/slider-2.jpg', { w: 1920 })} srcset={cfSrcset('images/home/slider-2.jpg')} sizes="100vw" alt="Offshore charter coverage" width="1920" height="1080" loading="eager" fetchpriority="high" decoding="async">
			</div>
			<div class="inner-desc">
				<div class="container">
					<h1 class="single-post-title display-2">Offshore charter coverage</h1>
					<span class="post-subtitle">Sportfishing</span>
				</div>
			</div>
		</div>
		<div id="wrap-content" class="page-content custom-page-template">
			<div class="section-holder" style="padding: 60px 0;">
				<div class="container">
					<a href="/portfolio-sportfishing" class="read-more" style="margin-bottom: 40px; display: inline-block;"><i class="fa fa-chevron-left" style="margin-right: 8px;"></i> Back to Sportfishing</a>
					<div style="margin-bottom: 50px;">
						<div class="el-smalltitle">Sportfishing</div>
						<h2 class="display-4 margin-b30">Offshore charter coverage</h2>
						<p style="max-width: 700px;">Documenting offshore fishing charters from the dock to the deep blue — every strike, every run, every victory.</p>
					</div>
					<div class="row">
						<div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
							<div class="ao-gallery-item">
								<img src={cfImg('images/portfolio/featured-images/sf-charter-1.jpg', { w: 640 })} srcset={cfSrcset('images/portfolio/featured-images/sf-charter-1.jpg', { widths: [320, 480, 640] })} alt="Shotski — Rehoboth Beach, DE" sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw" width="640" height="427" loading="lazy" decoding="async" style="width: 100%; display: block;">
							</div>
							<p class="ao-gallery-caption" style="margin-top: 10px; font-size: 14px; color: #858585;">Shotski — Rehoboth Beach, DE</p>
						</div>
						<div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
							<div class="ao-gallery-item">
								<img src={cfImg('images/portfolio/featured-images/sf-charter-2.jpg', { w: 640 })} srcset={cfSrcset('images/portfolio/featured-images/sf-charter-2.jpg', { widths: [320, 480, 640] })} alt="Hey Honey heading offshore" sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw" width="640" height="427" loading="lazy" decoding="async" style="width: 100%; display: block;">
							</div>
							<p class="ao-gallery-caption" style="margin-top: 10px; font-size: 14px; color: #858585;">Hey Honey heading offshore</p>
						</div>
						<div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
							<div class="ao-gallery-item">
								<img src={cfImg('images/portfolio/featured-images/sf-charter-3.jpg', { w: 640 })} srcset={cfSrcset('images/portfolio/featured-images/sf-charter-3.jpg', { widths: [320, 480, 640] })} alt="Gold reel detail shot" sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw" width="640" height="427" loading="lazy" decoding="async" style="width: 100%; display: block;">
							</div>
							<p class="ao-gallery-caption" style="margin-top: 10px; font-size: 14px; color: #858585;">Gold reel detail shot</p>
						</div>
						<div class="col-lg-4 col-md-6" style="margin-bottom: 30px;">
							<div class="ao-gallery-item">
								<img src={cfImg('images/portfolio/featured-images/sf-charter-4.jpg', { w: 640 })} srcset={cfSrcset('images/portfolio/featured-images/sf-charter-4.jpg', { widths: [320, 480, 640] })} alt="Rods lined up for the run" sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw" width="640" height="427" loading="lazy" decoding="async" style="width: 100%; display: block;">
							</div>
							<p class="ao-gallery-caption" style="margin-top: 10px; font-size: 14px; color: #858585;">Rods lined up for the run</p>
						</div>
					</div>
				</div>
			</div>
			<div class="section-holder section-info padding-tb100 section-nomargin" style="background: var(--primary-color);">
				<div class="container">
					<div class="row">
						<div class="col-lg-12">
							<div class="padding-lr200 alignc">
								<h2 class="display-4 margin-b30" style="color: #fff;">Like what you see?</h2>
								<p style="color: rgba(255,255,255,0.8);">Let's capture your next project from a whole new perspective.</p>
								<a href="/contact" class="read-more white-btn margin-t30">Book a Session</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
</Base>
