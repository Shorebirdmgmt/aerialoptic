---
import Base from '../layouts/Base.astro';
import { cfImg, cfSrcset } from '../lib/img';
import { fetchPhotos } from '../lib/api';

const PORTFOLIO_CATEGORIES = [
  { name: 'Powerboats', slug: 'powerboats', subtitle: 'High-performance boats on the Chesapeake' },
  { name: 'Sportfishing', slug: 'sportfishing', subtitle: 'Offshore action and tournament coverage' },
  { name: 'Local Business', slug: 'local-business', subtitle: 'Aerial views that put local brands on the map' },
  { name: 'Construction', slug: 'construction', subtitle: 'Documenting progress from above' },
  { name: 'Real Estate', slug: 'realestate', subtitle: 'Stunning property aerials that sell' },
  { name: 'Events', slug: 'events', subtitle: 'Car shows, boat rallies, and community gatherings' },
];

const allPhotos = await fetchPhotos();

// Group photos by category and find the first photo for each category card
const categoryPhotos = new Map<string, typeof allPhotos>();
for (const photo of allPhotos) {
  const existing = categoryPhotos.get(photo.category) || [];
  existing.push(photo);
  categoryPhotos.set(photo.category, existing);
}

// Build category cards with thumbnail from first photo
const categories = PORTFOLIO_CATEGORIES.map((cat) => {
  const photos = categoryPhotos.get(cat.name) || [];
  const thumbnail = photos[0];
  return { ...cat, thumbnail };
}).filter((cat) => cat.thumbnail);
---
<Base title="Drone Photography Portfolio | Aerial Optic" description="Browse our aerial photography portfolio — powerboats, sportfishing, real estate, construction, events, and local businesses." currentPage="portfolio" heroPreload={cfSrcset('images/home/slider-1.jpg')} ogImage={cfImg('images/home/slider-1.jpg', { w: 1200, q: 80 })}>
		<!-- PAGE HERO -->
		<div class="top-single-bkg" style="height: 65vh;">
			<div class="topsingleimg">
				<img src={cfImg('images/home/slider-1.jpg', { w: 1920 })} srcset={cfSrcset('images/home/slider-1.jpg')} sizes="100vw" alt="Our Portfolio" width="1920" height="1080" loading="eager" fetchpriority="high" decoding="async">
			</div>
			<div class="inner-desc">
				<div class="container">
					<h1 class="single-post-title display-2">Our Portfolio</h1>
					<span class="post-subtitle">A selection of our aerial photography and videography work</span>
				</div>
			</div>
		</div>
		<!-- /PAGE HERO -->
		<!-- WRAP CONTENT -->
		<div id="wrap-content" class="page-content custom-page-template">
			<!-- CATEGORY CARDS -->
			<div class="section-holder" style="padding: 80px 0;">
				<div class="container">
					<div class="alignc" style="margin-bottom: 60px;">
						<div class="el-smalltitle sr">Our work</div>
						<h2 class="display-4 margin-b30 sr sr-delay-1">Browse by category</h2>
						<p class="sr sr-delay-2">Select a category to explore our aerial photography portfolio</p>
					</div>
					<div class="row">
						{categories.map((cat, i) => (
							<div class={`col-lg-4 col-md-6 sr sr-delay-${i + 1}`} style="margin-bottom: 30px;">
								<a href={`/portfolio-${cat.slug}`} style="display: block; text-decoration: none; color: inherit;">
									<div class="portfolio-card" style="position: relative; overflow: hidden;">
										<img src={cfImg(cat.thumbnail!.r2_key, { w: 640 })} srcset={cfSrcset(cat.thumbnail!.r2_key, { widths: [320, 480, 640] })} sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, 33vw" alt={cat.name} width="640" height="480" loading="lazy" decoding="async" style="width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block;">
										<div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 25px; text-align: center; background: linear-gradient(transparent, rgba(0,0,0,0.75));">
											<h3 style="color: #fff; margin: 0 0 5px; font-family: var(--headings-font); font-size: 1.5rem;">{cat.name}</h3>
											<span style="color: rgba(255,255,255,0.8); font-size: 14px;">{cat.subtitle}</span>
										</div>
									</div>
								</a>
							</div>
						))}
					</div>
				</div>
			</div>
			<!-- /CATEGORY CARDS -->
			<!-- CTA SECTION -->
			<div class="section-holder section-info padding-tb100 section-nomargin" style="background: var(--primary-color);">
				<div class="container">
					<div class="row">
						<div class="col-lg-12">
							<div class="padding-lr200 alignc">
								<h2 class="display-4 margin-b30" style="color: #fff;">Like what you see?</h2>
								<p style="color: rgba(255,255,255,0.8);">Let's capture your next project from a whole new perspective.</p>
								<a href="/contact" class="read-more white-btn margin-t30">Book a Session</a>
							</div>
						</div>
					</div>
				</div>
			</div>
			<!-- /CTA SECTION -->
		</div>
		<!-- /WRAP CONTENT -->
</Base>
